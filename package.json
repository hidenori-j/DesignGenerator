{
  "name": "design-generator",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2",
    "husky": "^9",
    "lint-staged": "^15"
  },
  "lint-staged": {
    "apps/**/*.{ts,tsx}": [
      "biome check --write"
    ]
  },
  "packageManager": "bun@1.2.5"
}
