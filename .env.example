# =============================================================================
# DesignGenerator - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# --- GPU Mode ---
# local: Use local RTX 5080 only
# cloud: Use cloud APIs only
# hybrid: Local first, cloud fallback on VRAM exhaustion
GPU_MODE=hybrid

# --- OpenAI (GPT-5.4 Orchestrator) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4

# --- Fal.ai (FLUX.2 Pro / Cloud Generation) ---
FAL_AI_API_KEY=

# --- Adobe Firefly (Commercial-safe Generation) ---
ADOBE_FIREFLY_CLIENT_ID=
ADOBE_FIREFLY_CLIENT_SECRET=

# --- Figma (Design System Sync) ---
FIGMA_ACCESS_TOKEN=
FIGMA_FILE_ID=

# --- Qdrant (Vector Database) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# For Qdrant Cloud:
# QDRANT_URL=https://your-cluster.qdrant.io:6333

# --- Redis (Semantic Cache + Job Queue) ---
REDIS_URL=redis://localhost:6379

# --- PostgreSQL (Relational Data) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/designgen

# --- MinIO (S3-compatible Asset Storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=design-assets

# --- Agent Service ---
AGENT_SERVICE_URL=http://localhost:8000

# --- Generation Service ---
GENERATION_SERVICE_URL=http://localhost:8100

# --- Ingest Service ---
INGEST_SERVICE_URL=http://localhost:8200

# --- Collector Service ---
COLLECTOR_SERVICE_URL=http://localhost:8400

# --- GPU Arbiter ---
GPU_ARBITER_URL=http://localhost:8300
GPU_JOB_TIMEOUT_VLM=120
GPU_JOB_TIMEOUT_GENERATION=300
GPU_DLQ_MAX_RETRIES=3

# --- JWT Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=3600

# --- Vertical Slice / Mock ---
# Set MOCK_API=true to have API Gateway return mock data without Agent service
MOCK_API=false

# --- Unsplash API (for Collector) ---
UNSPLASH_ACCESS_KEY=

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
